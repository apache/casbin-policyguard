    "eject": "craco eject",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "fix": "eslint --fix 'src/**/*.{js,jsx,ts,tsx}'"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "ie 9, ie 10, ie 11"
